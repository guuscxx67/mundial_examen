{
  "name": "mundial-2026",
  "version": "1.0.0",
  "description": "Sistema de Simulacion, Administracion y Geolocalizacion de la Copa Mundial FIFA 2026",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:logs": "docker compose logs -f db"
  },
  "keywords": [
    "mundial",
    "fifa",
    "2026",
    "postgresql",
    "geolocalizacion",
    "rest-api"
  ],
  "author": "Equipo Mundial 2026",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "pg": "^8.12.0"
  }
}
